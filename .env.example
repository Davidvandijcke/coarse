# coarse — AI paper reviewer
# Copy this file to .env and fill in the keys you have.
# Only OPENROUTER_API_KEY is required; all others are optional.

# Required: routes all LLM calls (including Mistral OCR for PDF extraction)
# through OpenRouter. Get one at https://openrouter.ai/keys.
OPENROUTER_API_KEY=

# Optional: use these providers directly instead of through OpenRouter
# (lower latency, separate billing).
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# MISTRAL_API_KEY=
# GROQ_API_KEY=
# TOGETHER_API_KEY=
# COHERE_API_KEY=

# Optional: deployment/admin access for working on coarse infra locally.
# Keep these only in your untracked .env, never in git.
#
# Direct database access is the simplest programmatic control path for
# Supabase because it lets you apply SQL migrations and inspect tables
# without relying on the Management API.
# PROD_SUPABASE_DB_URL=postgresql://postgres:...@db.<prod-ref>.supabase.co:5432/postgres
# PREVIEW_SUPABASE_DB_URL=postgresql://postgres:...@db.<preview-ref>.supabase.co:5432/postgres
#
# Preview web/backend wiring.
# PREVIEW_SUPABASE_URL=https://<preview-ref>.supabase.co
# PREVIEW_SUPABASE_ANON_KEY=
# PREVIEW_SUPABASE_SERVICE_KEY=
# PREVIEW_MODAL_FUNCTION_URL=https://<workspace>-preview--coarse-review-run-review.modal.run
# PREVIEW_MODAL_EXTRACT_URL=https://<workspace>-preview--coarse-mcp-run-extract.modal.run
# PREVIEW_MODAL_WEBHOOK_SECRET=
