# Supabase project credentials (get from supabase.com dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service key (server-side only, never expose to client)
SUPABASE_SERVICE_KEY=your-service-role-key

# Modal function endpoint (set after `modal deploy`)
MODAL_FUNCTION_URL=https://your-org--coarse-review-run-review.modal.run

# Shared secret to authenticate calls to Modal webhook
MODAL_WEBHOOK_SECRET=your-shared-secret

# Gmail SMTP for email notifications
# Create an App Password: Google Account → Security → 2-Step Verification → App Passwords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Public site URL (used in email links)
NEXT_PUBLIC_SITE_URL=https://coarse.vercel.app
